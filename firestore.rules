rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation helper for HistoryEntry
    function isValidHistoryEntry(data) {
      return data.songId is string && data.songId.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.artist is string && data.artist.size() <= 200
        && (!data.keys().hasAll(['coverUrl']) || (data.coverUrl is string && data.coverUrl.size() <= 1000))
        && data.userId == request.auth.uid
        && data.playedAt is string && data.playedAt.size() <= 100;
    }

    // Strict keys validation for HistoryEntry create
    function hasStrictKeysForHistoryCreate(data) {
      return data.keys().hasAll(['songId', 'title', 'artist', 'userId', 'playedAt'])
        && (data.keys().size() == 5 || (data.keys().size() == 6 && data.keys().hasAll(['coverUrl'])));
    }

    // Match block for user specific history collection
    match /users/{userId}/history/{historyId} {
      // Allow single document get and lists of user's own history
      allow get, list: if isOwner(userId);

      // Create history entry: Must be the owner, have a valid ID, and valid fields
      allow create: if isOwner(userId)
        && isValidId(historyId)
        && isValidHistoryEntry(request.resource.data)
        && hasStrictKeysForHistoryCreate(request.resource.data);

      // Delete history entry: Only the owner can delete
      allow delete: if isOwner(userId)
        && isValidId(historyId);

      // History entries are immutable: updates are not allowed
      allow update: if false;
    }
  }
}
